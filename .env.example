# ─────────────────────────────────────────────────────────────────────────────
# Central CMS — environment template. Copy to `.env.local` and fill in.
# Only the Central CMS holds DATABASE_URL. Frontends and engines talk HTTP only.
# ─────────────────────────────────────────────────────────────────────────────

# Postgres (Supabase). Pooled URL for runtime; direct URL for migrations (DDL).
DATABASE_URL=postgresql://user:pass@host:6543/postgres
DATABASE_DIRECT_URL=postgresql://user:pass@host:5432/postgres

# Payload — generate with: openssl rand -hex 32
PAYLOAD_SECRET=

# First system-admin user, created by the seed script.
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-me-now

# Cloudflare R2 (S3-compatible). One bucket, per-tenant key prefix.
# Omit all four locally to fall back to local-disk media in dev.
R2_BUCKET=central-media
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Signing secret for preview tokens and revalidate webhooks (HMAC).
# generate with: openssl rand -hex 32
CENTRAL_SIGNING_SECRET=

# Comma-separated list of frontend origins allowed to call the public API (CORS).
# e.g. https://briefasia.com,https://dailytechwire.com
PUBLIC_API_ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3002
