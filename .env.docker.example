# ─────────────────────────────────────────────────────────────────────────────
# Central CMS — LOCAL DOCKER environment. Copy to `.env.local`:
#
#   docker compose up -d                 # start the local Postgres (this file's DB)
#   cp .env.docker.example .env.local
#   npm install && npm run db:seed       # PAYLOAD_DB_PUSH=true syncs the schema, then seeds
#   npm run dev                          # admin at http://localhost:3000/admin
#
# Values match docker-compose.yml defaults (postgres / password / central_cms /
# host port 54326). These are DEV-ONLY secrets — never use them in deployed envs.
# ─────────────────────────────────────────────────────────────────────────────

# Local Postgres from docker-compose.yml (pooled + direct are the same locally).
DATABASE_URL=postgresql://postgres:password@localhost:54326/central_cms
DATABASE_DIRECT_URL=postgresql://postgres:password@localhost:54326/central_cms

# No committed migrations yet — let Payload sync the schema on boot for local dev.
PAYLOAD_DB_PUSH=true

# Payload — any non-empty string locally. Generate real ones with: openssl rand -hex 32
PAYLOAD_SECRET=dev-only-payload-secret-change-me-0000000000000000
CENTRAL_SIGNING_SECRET=dev-only-signing-secret-change-me-0000000000000000

# First system-admin user, created by the seed script.
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-me-now

# Pins a deterministic engine token for the local engine-intake-tester loop.
# Must match ENGINE_INTAKE_TOKEN in engine-intake-tester/.env.
SEED_ENGINE_TOKEN=localdev-engine-intake-token-rotate-me

# R2 omitted on purpose — falls back to local-disk media in dev.

# Frontend origins allowed to call the public API (CORS).
PUBLIC_API_ALLOWED_ORIGINS=http://localhost:3001,http://localhost:3002
